# Copy to .env.local for local dev, or set these in Vercel → Project → Settings → Environment Variables.

# Session signing secret (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-string

# GRSAI — reads live screenshots / bulk analytics with Gemini 2.5 Flash.
# OpenAI-compatible chat endpoint; the base MUST end in /v1.
GRSAI_API_KEY=
GRSAI_BASE_URL=https://grsaiapi.com/v1
GRSAI_MODEL=gemini-2.5-flash

# Bearer key PeningLab uses to POST /api/posts/ingest
INGEST_API_KEY=
