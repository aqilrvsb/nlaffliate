# Copy to .env.local for local dev, and set the same in
# Vercel → Project → Settings → Environment Variables.

# ── Database (Supabase Postgres) ────────────────────────────────
# Supabase Dashboard → Project Settings → Database → Connection string → URI
# Use the "Transaction pooler" (port 6543) for serverless.
DATABASE_URL=postgresql://postgres.<ref>:<PASSWORD>@aws-1-<region>.pooler.supabase.com:6543/postgres

# ── Supabase Storage (screenshot / report image uploads) ────────
SUPABASE_URL=https://adcirrbvyovnikchupph.supabase.co
# Project Settings → API → service_role (SECRET — server-side only)
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth ────────────────────────────────────────────────────────
# Long random string; signs the session cookie.
JWT_SECRET=change-me-to-a-long-random-string

# ── GRSAI (Gemini 2.5 Flash image reading) ──────────────────────
# Can also be set by an admin in-app under Admin → AI Reader.
GRSAI_API_KEY=
GRSAI_BASE_URL=https://grsaiapi.com/v1
GRSAI_MODEL=gemini-2.5-flash

# ── PeningLab ingest ────────────────────────────────────────────
# Bearer key PeningLab uses to POST /api/posts/ingest
INGEST_API_KEY=
